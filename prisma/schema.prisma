generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id                  Int    @id @default(1)
  name                String @default("Me")
  activeCalorieGoal   Int    @default(2400)
  inactiveCalorieGoal Int    @default(2000)
  proteinGoal         Int    @default(150)
  fiberGoal           Int    @default(25)
  waterGoal           Int    @default(8)
}

model DailyLog {
  id           Int            @id @default(autoincrement())
  date         String         @unique
  note         String?
  isActiveDay  Boolean?
  waterGlasses Int            @default(0)
  entries      CalorieEntry[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Note {
  id        Int      @id @default(autoincrement())
  body      String
  createdAt DateTime @default(now())
}

model CalorieEntry {
  id        Int      @id @default(autoincrement())
  logId     Int
  log       DailyLog @relation(fields: [logId], references: [id], onDelete: Cascade)
  sourceKey String?
  quantity  Float    @default(1)
  label     String?
  calories  Int?
  protein   Float?
  fiber     Float?
}

model FoodSource {
  id          Int     @id @default(autoincrement())
  key         String  @unique
  label       String
  calories    Int
  protein     Float   @default(0)
  fiber       Float   @default(0)
  waterGlasses Float  @default(0)
  unit        String  @default("serving")
  emoji       String  @default("🍽️")
  active      Boolean @default(true)
  sortOrder   Int     @default(0)
}
